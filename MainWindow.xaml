<Window x:Class="CursorMagic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CursorMagic.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Cursor Magic" Height="780" Width="1180" MinHeight="680" MinWidth="1020"
        WindowStyle="None" ResizeMode="CanResize" Icon="{StaticResource AppMark}"
        Closing="Window_Closing" StateChanged="Window_StateChanged" Loaded="Window_Loaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A0D12" Offset="0" />
            <GradientStop Color="#111827" Offset="0.55" />
            <GradientStop Color="#15101B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <DataTemplate DataType="{x:Type models:CursorTheme}">
            <Grid Margin="10" MinHeight="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="48" Height="48" Background="#0A0D12" BorderBrush="#2C384B" BorderThickness="1" CornerRadius="8">
                    <Image Source="{Binding PreviewPath}" Stretch="Uniform" Margin="6" RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                        <Border Background="#163729" BorderBrush="#42D18C" BorderThickness="1" CornerRadius="5" Padding="6,1" Margin="8,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="ON" Foreground="#88F3B3" FontSize="10" FontWeight="Bold" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0A0D12"
                BorderBrush="#202B3D"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="{StaticResource AppMark}" Width="22" Height="22" Margin="0,0,9,0" />
                    <TextBlock Text="Cursor Magic" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="-" Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton" Content="[]" Style="{StaticResource ChromeButton}" Click="MaximizeButton_Click" />
                    <Button Content="X" Style="{StaticResource ChromeButton}" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PanelBorder}" Padding="20" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Cursor Magic" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="Windows cursor themes with tuned click effects" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="PauseEffectsCheckBox" Content="Pause effects" Margin="0,0,18,0" Checked="PauseEffects_Changed" Unchecked="PauseEffects_Changed" />
                        <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows" Margin="0,0,18,0" Checked="StartWithWindows_Changed" Unchecked="StartWithWindows_Changed" />
                        <CheckBox x:Name="RestoreOnExitCheckBox" Content="Restore on exit" Margin="0,0,18,0" Checked="RestoreOnExit_Changed" Unchecked="RestoreOnExit_Changed" />
                        <Button Content="Restore defaults" Click="RestoreDefaults_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1">
                <TabItem Header="Library">
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelBorder}" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Themes" FontSize="18" FontWeight="SemiBold" Margin="4,0,0,14" />
                                <ListBox Grid.Row="1" x:Name="ThemesListBox" SelectionChanged="ThemesListBox_SelectionChanged" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="28">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="270" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <Border Width="230" Height="230" Background="#090C11" BorderBrush="#2C384B" BorderThickness="1" CornerRadius="8">
                                        <Image x:Name="ThemePreviewImage" Stretch="Uniform" Margin="24" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>
                                    <WrapPanel Margin="0,22,0,0">
                                        <Button Content="Apply" Background="{StaticResource AccentPink}" BorderBrush="#FF8AC8" Click="ApplyTheme_Click" />
                                        <Button Content="Preview" Click="PreviewEffect_Click" />
                                        <Button Content="Export pack" Click="ExportTheme_Click" />
                                        <Button Content="Import pack" Click="ImportTheme_Click" />
                                    </WrapPanel>
                                </StackPanel>

                                <Grid Grid.Column="1" Margin="10,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <Border HorizontalAlignment="Left" Background="#17263A" BorderBrush="#365675" BorderThickness="1" CornerRadius="7" Padding="10,4">
                                            <TextBlock x:Name="ThemeCategoryText" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="SemiBold" />
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,14,0,4">
                                            <TextBlock x:Name="ThemeNameText" FontSize="34" FontWeight="Bold" />
                                            <Border x:Name="ActiveThemeBadge" Background="#163729" BorderBrush="#42D18C" BorderThickness="1" CornerRadius="7" Padding="10,4" Margin="14,9,0,0" Visibility="Collapsed">
                                                <TextBlock Text="ACTIVE" Foreground="#88F3B3" FontSize="12" FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock x:Name="ThemeDescriptionText" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" FontSize="15" MaxWidth="590" />
                                    </StackPanel>

                                    <Grid Grid.Row="1" Margin="0,26,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Background="{StaticResource PanelAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="8" Padding="18">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Animation" Style="{StaticResource SectionTitle}" />
                                                    <ComboBox x:Name="ThemeEffectComboBox" SelectionChanged="ThemeEffectComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Theme default" />
                                                        <ComboBoxItem Content="Star Wand" />
                                                        <ComboBoxItem Content="Sparkles" />
                                                        <ComboBoxItem Content="Hearts" />
                                                        <ComboBoxItem Content="Rings" />
                                                        <ComboBoxItem Content="Fireflies" />
                                                    </ComboBox>
                                                    <TextBlock Text="Theme color" Style="{StaticResource SectionTitle}" Margin="0,16,0,8" />
                                                    <ComboBox x:Name="ThemeColorComboBox" SelectionChanged="ThemeColorComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Cyan" Tag="#55F7FF" />
                                                        <ComboBoxItem Content="Green" Tag="#5DFF59" />
                                                        <ComboBoxItem Content="Blue" Tag="#4A67FF" />
                                                        <ComboBoxItem Content="Purple" Tag="#A673FF" />
                                                        <ComboBoxItem Content="Red" Tag="#FF3333" />
                                                        <ComboBoxItem Content="Gold" Tag="#FFD45E" />
                                                        <ComboBoxItem Content="White" Tag="#FFFFFF" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="24,0,0,0">
                                                    <TextBlock Text="{Binding ElementName=AnimationSizeSlider, Path=Value, StringFormat=Size {0:0.00}x}" Style="{StaticResource SectionTitle}" />
                                                    <Slider x:Name="AnimationSizeSlider" Minimum="0.45" Maximum="2" Value="1" TickFrequency="0.05" ValueChanged="AnimationSlider_Changed" />
                                                    <TextBlock Text="{Binding ElementName=AnimationBrightnessSlider, Path=Value, StringFormat=Brightness {0:0.00}x}" Style="{StaticResource SectionTitle}" Margin="0,16,0,8" />
                                                    <Slider x:Name="AnimationBrightnessSlider" Minimum="0.35" Maximum="1.8" Value="1" TickFrequency="0.05" ValueChanged="AnimationSlider_Changed" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="1" Background="#0E151F" BorderBrush="#263345" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,18,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="8" Height="36" Background="{StaticResource AccentGold}" CornerRadius="4" Margin="0,0,14,0" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Compatibility guard" FontWeight="SemiBold" />
                                                    <TextBlock Text="Effects pause over fullscreen and blocklisted apps." Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Creator">
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelBorder}" Padding="22">
                            <StackPanel>
                                <TextBlock Text="Create" FontSize="22" FontWeight="Bold" Margin="0,0,0,18" />
                                <TextBlock Text="Theme name" Style="{StaticResource SectionTitle}" />
                                <TextBox x:Name="CreatorNameTextBox" Text="My Custom Cursor" Margin="0,0,0,16" />
                                <Button Content="Import image" Click="ImportImage_Click" HorizontalAlignment="Left" Margin="0,0,0,10" />
                                <TextBlock x:Name="ImportedImageText" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,18" />

                                <TextBlock Text="{Binding ElementName=HotspotXSlider, Path=Value, StringFormat=Hotspot X {0:0}}" Style="{StaticResource SectionTitle}" />
                                <Slider x:Name="HotspotXSlider" Minimum="0" Maximum="47" Value="4" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="CreatorPreview_Changed" />
                                <TextBlock Text="{Binding ElementName=HotspotYSlider, Path=Value, StringFormat=Hotspot Y {0:0}}" Style="{StaticResource SectionTitle}" Margin="0,16,0,8" />
                                <Slider x:Name="HotspotYSlider" Minimum="0" Maximum="47" Value="4" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="CreatorPreview_Changed" />

                                <TextBlock Text="Click effect" Style="{StaticResource SectionTitle}" Margin="0,18,0,8" />
                                <ComboBox x:Name="EffectComboBox" SelectedIndex="0" Margin="0,0,0,16">
                                    <ComboBoxItem Content="Sparkles" />
                                    <ComboBoxItem Content="Hearts" />
                                    <ComboBoxItem Content="Rings" />
                                    <ComboBoxItem Content="Fireflies" />
                                </ComboBox>
                                <TextBlock Text="Accent layer" Style="{StaticResource SectionTitle}" />
                                <ComboBox x:Name="DecorationComboBox" SelectedIndex="0" Margin="0,0,0,24" SelectionChanged="CreatorPreview_Changed">
                                    <ComboBoxItem Content="None" />
                                    <ComboBoxItem Content="Star" />
                                    <ComboBoxItem Content="Heart" />
                                    <ComboBoxItem Content="Ring" />
                                </ComboBox>
                                <Button Content="Save theme" Background="{StaticResource AccentPink}" BorderBrush="#FF8AC8" Click="SaveCustomTheme_Click" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="28">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Preview" FontSize="22" FontWeight="Bold" />
                                <Grid Grid.Row="1" Margin="0,22,0,0">
                                    <Border Width="360" Height="360" Background="#090C11" BorderBrush="#2C384B" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <Grid>
                                            <Image x:Name="CreatorPreviewImage" Stretch="Uniform" Margin="52" RenderOptions.BitmapScalingMode="HighQuality" />
                                            <Canvas x:Name="HotspotCanvas">
                                                <Ellipse Width="12" Height="12" Stroke="#FFD45E" StrokeThickness="2" Fill="#33000000" />
                                                <Line X1="-8" Y1="0" X2="20" Y2="0" Stroke="#FFD45E" StrokeThickness="1" />
                                                <Line X1="6" Y1="-8" X2="6" Y2="20" Stroke="#FFD45E" StrokeThickness="1" />
                                            </Canvas>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Compatibility">
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="430" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelBorder}" Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Blocklist" FontSize="22" FontWeight="Bold" Margin="0,0,0,18" />
                                <ListBox Grid.Row="1" x:Name="BlocklistBox" />
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,18,0,0">
                                    <Button Content="Suspend current app" Click="SuspendCurrentApp_Click" />
                                    <Button Content="Remove selected" Click="RemoveBlockedApp_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="28">
                            <StackPanel>
                                <TextBlock Text="Foreground app" FontSize="22" FontWeight="Bold" />
                                <TextBlock x:Name="ForegroundAppText" FontSize="38" FontWeight="SemiBold" Margin="0,18,0,0" />
                                <TextBlock x:Name="FullscreenText" Foreground="{StaticResource TextMuted}" Margin="0,8,0,22" />
                                <Button Content="Refresh status" Click="RefreshForeground_Click" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="13" Margin="0,18,0,0">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource TextMuted}" />
            </Border>
        </Grid>
    </Grid>
</Window>
